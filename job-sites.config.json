{
  "jobSites": {
    "example": {
      "name": "Example Job Board",
      "urlPattern": "https://example.com/jobs/*",
      "selectors": {
        "title": "h1.job-title",
        "description": ".job-description",
        "company": ".company-name",
        "location": ".job-location"
      }
    },
    "outlier": {
      "name": "Outlier AI",
      "urlPattern": "https://app.outlier.ai/en/expert/opportunities/*",
      "selectors": {
        "title": "h1, .job-title, [data-testid='job-title']",
        "description": ".job-description, .description, [data-testid='job-description']",
        "company": ".company-name, [data-testid='company-name']",
        "location": ".location, [data-testid='location']",
        "requirements": ".requirements, .qualifications, [data-testid='requirements']"
      }
    },
    "monster": {
      "name": "Monster",
      "urlPattern": "https://www.monster.com/job-openings/*",
      "selectors": {
        "title": "h1, .job-title, [data-testid='job-title'], .mux-job-summary-header h2",
        "description": ".job-description, .description, [data-testid='job-description'], .mux-job-description",
        "company": ".company-name, [data-testid='company-name'], .mux-company-name",
        "location": ".location, [data-testid='location'], .mux-job-location",
        "salary": ".salary, [data-testid='salary'], .mux-salary"
      }
    },
    "nextstepsystems.com": {
      "name": "NextStep Systems",
      "urlPattern": "https://www.nextstepsystems.com/*",
      "selectors": {
        "title": "h1, .job-title, [data-testid='job-title']",
        "description": ".job-description, .description, [data-testid='job-description'], .entry-content",
        "company": ".company-name, [data-testid='company-name']",
        "location": ".location, [data-testid='location']"
      }
    }
  }
}
