<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cover Letter - {{ profile.name }}</title>
  <link rel="stylesheet" href="../styles/cover_letter.css">
</head>
<body>
  <div class="cover-letter-container">
    <article class="cover-letter-content">
      <!-- Sender Address -->
      <div class="sender-address">
        <p class="letter-meta">{{ profile.name }}</p>
        {% if profile.location %}
        <p class="letter-meta">{{ profile.location }}</p>
        {% endif %}
      </div>

      <!-- Date -->
      <p class="letter-date">{{ metadata.currentDate }}</p>

      <!-- Recipient Address -->
      <div class="recipient-address">
        {% if metadata.companyName %}<p class="letter-meta">{{ metadata.companyName }}</p>{% endif %}
        {% if metadata.companyAddress %}<p class="letter-meta">{{ metadata.companyAddress }}</p>{% endif %}
      </div>

      <!-- Salutation -->
      {% if coverLetter.greeting %}
      <p class="greeting">{{ coverLetter.greeting }}</p>
      {% else %}
      <p class="greeting">Dear Hiring Manager,</p>
      {% endif %}

      <!-- Body Paragraphs -->
      {% for paragraph in coverLetter.paragraphs %}
      <p class="letter-paragraph">{{ paragraph }}</p>
      {% endfor %}

      <!-- Closing -->
      {% if coverLetter.closing %}
      <p class="closing">{{ coverLetter.closing }}</p>
      {% else %}
      <p class="closing">Sincerely,</p>
      {% endif %}

      <!-- Signature Block with 4 blank lines for physical signature -->
      <div class="signature-block">
        <br><br><br><br>
        <p class="signature">{{ profile.name }}</p>
        {% if profile.email %}<p class="letter-meta signature-contact">{{ profile.email }}</p>{% endif %}
        {% if profile.phone %}<p class="letter-meta signature-contact">{{ profile.phone }}</p>{% endif %}
      </div>
    </article>

    <footer class="cover-letter-footer">
      <p><em>Application for: {{ metadata.jobTitle }}</em>{% if metadata.companyName %} at {{ metadata.companyName }}{% endif %}</p>
    </footer>
  </div>
</body>
</html>
