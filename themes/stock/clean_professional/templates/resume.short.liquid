<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ profile.name }} - Resume</title>
  <link rel="stylesheet" href="../styles/resume.css">
</head>
<body>
  <div class="resume-container">
    <header class="resume-header">
      <h1>{{ profile.name }}</h1>
      {% if profile.email %}
      <p class="contact-info">{{ profile.email }}</p>
      {% endif %}
      {% if profile.phone %}
      <p class="contact-info">{{ profile.phone }}</p>
      {% endif %}
      {% if profile.location %}
      <p class="contact-info">{{ profile.location }}</p>
      {% endif %}
    </header>

    {% if resume.summary %}
    <section class="resume-section">
      <h2>Summary</h2>
      <p>{{ resume.summary }}</p>
    </section>
    {% endif %}

    <section class="resume-section">
      <h2>Skills</h2>
      {% if resume.skills[0].category %}
      {% comment %} Grouped skills {% endcomment %}
      {% for group in resume.skills %}
      <div class="skills-group">
        <h3 class="skills-category">{{ group.category }}</h3>
        <ul class="skills-list">
          {% for skill in group.items %}
          <li>{{ skill }}</li>
          {% endfor %}
        </ul>
      </div>
      {% endfor %}
      {% else %}
      {% comment %} Flat skills list {% endcomment %}
      <ul class="skills-list">
        {% for skill in resume.skills %}
        <li>{{ skill }}</li>
        {% endfor %}
      </ul>
      {% endif %}
    </section>

    {% if resume.experience and resume.experience.size > 0 %}
    <section class="resume-section">
      <h2>Experience</h2>
      {% for job in resume.experience %}
      <div class="experience-item">
        <h3>{{ job.title }}</h3>
        <p class="company-name">{{ job.company }}</p>
        {% if job.bullets and job.bullets.size > 0 %}
        <ul class="experience-bullets">
          {% for bullet in job.bullets %}
          <li>{{ bullet }}</li>
          {% endfor %}
        </ul>
        {% endif %}
      </div>
      {% endfor %}
    </section>
    {% endif %}

    <footer class="resume-footer">
      <p>Generated on {% if metadata.generatedAt %}{{ metadata.generatedAt }}{% else %}{{ build.timestamp }}{% endif %}</p>
    </footer>
  </div>
</body>
</html>
