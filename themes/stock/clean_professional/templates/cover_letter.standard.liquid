<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cover Letter - {{ profile.name }}</title>
  {% if outputStyles and outputStyles.size > 0 %}
    {% for style in outputStyles %}
  <link rel="stylesheet" href="{{ style }}">
    {% endfor %}
  {% else %}
  <link rel="stylesheet" href="styles/resume.css">
  {% endif %}
</head>
<body>
  <div class="resume-container">
    <article class="cover-letter-content">
      <!-- Sender Address -->
      <div class="sender-address">
        <p>{{ profile.name }}</p>
        {% if profile.location %}<p>{{ profile.location }}</p>{% endif %}
      </div>

      <!-- Date -->
      <p class="letter-date">{{ metadata.currentDate }}</p>

      <!-- Recipient Address -->
      <div class="recipient-address">
        {% if metadata.companyName %}<p>{{ metadata.companyName }}</p>{% endif %}
      </div>

      <!-- Salutation -->
      {% if coverLetter.greeting %}
      <p class="greeting">{{ coverLetter.greeting }}</p>
      {% else %}
      <p class="greeting">Dear Hiring Manager,</p>
      {% endif %}

      <!-- Body Paragraphs -->
      {% for paragraph in coverLetter.paragraphs %}
      <p class="letter-paragraph">{{ paragraph }}</p>
      {% endfor %}

      <!-- Closing -->
      {% if coverLetter.closing %}
      <p class="closing">{{ coverLetter.closing }}</p>
      {% else %}
      <p class="closing">Sincerely,</p>
      {% endif %}

      <!-- Signature Block with 4 blank lines for physical signature -->
      <div class="signature-block">
        <br><br><br><br>
        <p class="signature-name">{{ profile.name }}</p>
        {% if profile.email %}<p class="signature-contact">{{ profile.email }}</p>{% endif %}
        {% if profile.phone %}<p class="signature-contact">{{ profile.phone }}</p>{% endif %}
      </div>
    </article>
  </div>
</body>
</html>
