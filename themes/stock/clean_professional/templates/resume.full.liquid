<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ profile.name }} - Resume</title>
  <link rel="stylesheet" href="../styles/resume.css">
</head>
<body>
  <div class="resume-container">
    <header class="resume-header">
      <h1>{{ profile.name }}</h1>
      {% if profile.email %}
      <p class="contact-info">{{ profile.email }}</p>
      {% endif %}
      {% if profile.phone %}
      <p class="contact-info">{{ profile.phone }}</p>
      {% endif %}
      {% if profile.location %}
      <p class="contact-info">{{ profile.location }}</p>
      {% endif %}
      {% if profile.linkedin %}
      <p class="contact-info">{{ profile.linkedin }}</p>
      {% endif %}
      {% if profile.github %}
      <p class="contact-info">{{ profile.github }}</p>
      {% endif %}
    </header>

    {% if resume.summary %}
    <section class="resume-section">
      <h2>Summary</h2>
      <p>{{ resume.summary }}</p>
    </section>
    {% endif %}

    <section class="resume-section">
      <h2>Skills</h2>
      {% if resume.skills[0].category %}
      {% comment %} Grouped skills {% endcomment %}
      {% for group in resume.skills %}
      <div class="skills-group">
        <h3 class="skills-category">{{ group.category }}</h3>
        <ul class="skills-list">
          {% for skill in group.items %}
          <li>{{ skill }}</li>
          {% endfor %}
        </ul>
      </div>
      {% endfor %}
      {% else %}
      {% comment %} Flat skills list {% endcomment %}
      <ul class="skills-list">
        {% for skill in resume.skills %}
        <li>{{ skill }}</li>
        {% endfor %}
      </ul>
      {% endif %}
    </section>

    {% if resume.experience and resume.experience.size > 0 %}
    <section class="resume-section">
      <h2>Professional Experience</h2>
      {% for job in resume.experience %}
      <div class="experience-item">
        <h3>{{ job.title }}</h3>
        <p class="company-name">{{ job.company }}{% if job.location %} - {{ job.location }}{% endif %}</p>
        <p class="employment-period">
          {% if job.startDate %}{{ job.startDate | date: "%B %Y" }}{% endif %}
          {% if job.endDate %}
            — {{ job.endDate | date: "%B %Y" }}
          {% else %}
            — Present
          {% endif %}
        </p>
        {% if job.bullets and job.bullets.size > 0 %}
        <ul class="experience-bullets">
          {% for bullet in job.bullets %}
          <li>{{ bullet }}</li>
          {% endfor %}
        </ul>
        {% endif %}
      </div>
      {% endfor %}
    </section>
    {% endif %}

    {% if resume.volunteering and resume.volunteering.size > 0 %}
    <section class="resume-section">
      <h2>Volunteering & Leadership</h2>
      {% for volunteer in resume.volunteering %}
      <div class="experience-item">
        <h3>{{ volunteer.title }}</h3>
        <p class="company-name">{{ volunteer.organization }}{% if volunteer.location %} - {{ volunteer.location }}{% endif %}</p>
        {% if volunteer.startDate or volunteer.endDate %}
        <p class="employment-period">
          {% if volunteer.startDate %}{{ volunteer.startDate | date: "%B %Y" }}{% endif %}
          {% if volunteer.endDate %}
            — {{ volunteer.endDate | date: "%B %Y" }}
          {% endif %}
        </p>
        {% endif %}
        {% if volunteer.bullets and volunteer.bullets.size > 0 %}
        <ul class="experience-bullets">
          {% for bullet in volunteer.bullets %}
          <li>{{ bullet }}</li>
          {% endfor %}
        </ul>
        {% endif %}
      </div>
      {% endfor %}
    </section>
    {% endif %}

    {% if resume.education and resume.education.size > 0 %}
    <section class="resume-section">
      <h2>Education</h2>
      {% for edu in resume.education %}
      <div class="education-item">
        <h3>{{ edu.degree }}</h3>
        <p class="institution-name">{{ edu.institution }}{% if edu.field %} - {{ edu.field }}{% endif %}</p>
        {% if edu.startDate or edu.endDate %}
        <p class="education-period">
          {% if edu.startDate %}{{ edu.startDate | date: "%B %Y" }}{% endif %}
          {% if edu.endDate %}
            — {{ edu.endDate | date: "%B %Y" }}
          {% endif %}
        </p>
        {% endif %}
        {% if edu.gpa %}
        <p class="education-gpa">GPA: {{ edu.gpa }}</p>
        {% endif %}
        {% if edu.bullets and edu.bullets.size > 0 %}
        <ul class="education-bullets">
          {% for bullet in edu.bullets %}
          <li>{{ bullet }}</li>
          {% endfor %}
        </ul>
        {% endif %}
      </div>
      {% endfor %}
    </section>
    {% endif %}

    {% if resume.projects and resume.projects.size > 0 %}
    <section class="resume-section">
      <h2>Projects</h2>
      {% for project in resume.projects %}
      <div class="project-item">
        <h3>{{ project.name }}{% if project.url %} <a href="{{ project.url }}" target="_blank" rel="noopener">🔗</a>{% endif %}</h3>
        {% if project.description %}
        <p class="project-description">{{ project.description }}</p>
        {% endif %}
        {% if project.technologies and project.technologies.size > 0 %}
        <p class="project-tech"><strong>Technologies:</strong> {{ project.technologies | join: ", " }}</p>
        {% endif %}
        {% if project.startDate or project.endDate %}
        <p class="project-period">
          {% if project.startDate %}{{ project.startDate | date: "%B %Y" }}{% endif %}
          {% if project.endDate %}
            — {{ project.endDate | date: "%B %Y" }}
          {% endif %}
        </p>
        {% endif %}
      </div>
      {% endfor %}
    </section>
    {% endif %}

    <footer class="resume-footer">
      <p>Generated on {% if metadata.generatedAt %}{{ metadata.generatedAt }}{% else %}{{ build.timestamp }}{% endif %}</p>
    </footer>
  </div>
</body>
</html>
